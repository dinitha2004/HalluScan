# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Virtual envs (we reuse se_probes_env / bleurt_env from the source repos — never vendored here)
*env*/
venv/

# Data / caches generated by the pipeline (regenerable)
data/*.parquet
data/*.npy
data/*.json
data/*.jsonl
data/*.csv
!data/.gitkeep

# Large / regenerable model caches
*.log
*.bak

# Recoverable dead-ends moved out of the working tree (kept on disk, not part of the prototype)
trash/

# OS
Thumbs.db
.DS_Store

# Office temp/lock files
~$*
